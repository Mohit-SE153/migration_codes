# Copy to .env for local dev only. In real deployments these are injected
# by a secrets manager (AWS Secrets Manager / Azure Key Vault / Vault) as
# environment variables -- never commit a populated .env.

# --- Run mode ---
# "fixture" runs entirely against the synthetic sample environment in
# fixtures/ (no network access required). "live" connects to a real
# SQL Server instance using the settings below.
AUTOVISTA_RUN_MODE=fixture

# --- SQL Server / SSISDB connection (required when AUTOVISTA_RUN_MODE=live) ---
# Use a read-only, least-privilege service account. Grant it VIEW SERVER
# STATE, VIEW ANY DEFINITION, and db_datareader on SSISDB + source DBs --
# nothing more. It should never have write permissions anywhere.
AUTOVISTA_SQL_HOST=
AUTOVISTA_SQL_DATABASE=
AUTOVISTA_SQL_USERNAME=
AUTOVISTA_SQL_PASSWORD=
AUTOVISTA_SQL_INTEGRATED_AUTH=false
AUTOVISTA_SQL_DRIVER=ODBC Driver 18 for SQL Server
AUTOVISTA_SQL_ENCRYPT=true
# ODBC Driver 18 validates the server certificate strictly by default and
# will refuse to connect to a self-signed/internal-CA cert with error 08001
# "SSL routines::certificate verify failed". Set this to true only on a
# trusted internal network -- it disables MITM protection on the connection.
AUTOVISTA_SQL_TRUST_SERVER_CERT=false

# Only needed if some packages are file-deployed rather than in SSISDB.
AUTOVISTA_DTSX_DIR=

# --- LLM fallback (optional, off by default) ---
# Used only for constructs no static parser can resolve (Script Task
# bodies, dynamic SQL). Never enable this expecting it to produce ground
# truth for row counts/sizes -- those always come from direct queries.
AUTOVISTA_LLM_FALLBACK_ENABLED=false
ANTHROPIC_API_KEY=
AUTOVISTA_LLM_MODEL=claude-sonnet-5
AUTOVISTA_LLM_MAX_OBJECTS_PER_RUN=200

# --- State / output ---
AUTOVISTA_STATE_DB=./autovista_state.sqlite3
AUTOVISTA_OUTPUT_DIR=./output

# --- Lakebridge Discovery (independent second Discovery engine) ---
# Uses the same AUTOVISTA_SQL_* / AUTOVISTA_RUN_MODE / AUTOVISTA_DTSX_DIR
# settings above to point at the same source database -- these are the
# only settings shared between the two engines. Everything below is
# Lakebridge-specific. See README.md "Lakebridge Discovery" for setup.
LAKEBRIDGE_ENABLED=true
# Path/name of the Databricks CLI executable (must have `labs lakebridge`
# installed via `databricks labs install lakebridge` -- see README).
LAKEBRIDGE_CLI_PATH=databricks
# --source-tech values passed to `databricks labs lakebridge analyze`.
# Must match the CLI's exact supported-technology labels (case-sensitive) --
# short slugs like "mssql"/"ssis" are rejected and silently drop the CLI
# into an interactive prompt, which then hangs until LAKEBRIDGE_ANALYZE_TIMEOUT_SECONDS.
LAKEBRIDGE_SOURCE_TECH_SQL=MS SQL Server
LAKEBRIDGE_SOURCE_TECH_ETL=SSIS
LAKEBRIDGE_GENERATE_JSON=true
LAKEBRIDGE_ANALYZE_TIMEOUT_SECONDS=1800
LAKEBRIDGE_OUTPUT_DIR=./output_lakebridge
LAKEBRIDGE_SOURCE_EXPORT_DIR=./output_lakebridge/_source_export
# Independent SQL Server catalog-metadata dependency discovery (foreign
# keys, user-defined types, XML schema collections, ...) -- requires
# AUTOVISTA_RUN_MODE=live (no real catalog to query in fixture mode).
# "*" = every registered probe (default), "" or "none" = disabled entirely,
# otherwise a comma-separated allowlist of probe names, e.g. "foreign_keys".
LAKEBRIDGE_CATALOG_METADATA_SOURCES=*

# --- Discovery Comparison ---
COMPARISON_OUTPUT_DIR=./output_comparison
