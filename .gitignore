# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# Virtual environment
.venv/
venv/
env/

# Test / tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage

# Local secrets / connection config -- never commit real credentials.
# .env.example stays tracked as the documented template.
.env

# Runtime state and generated Discovery output (regenerated by every run;
# see README "Running discovery"). output/sample_run/ is the one
# intentionally committed reference example and stays tracked.
autovista_state.sqlite3
*.sqlite3
output/*
!output/sample_run/
!output/sample_run/**

# Generated by tools/validate_sqlglot_dependencies.py -- regenerated every run.
output_validation/

# Scratch directory used by tests/test_dependency_coverage_validator.py's
# write_reports() regression tests (see that file for why it's under the
# repo root rather than tmp_path/%TEMP%). Each test cleans up its own
# subdirectory; this is a safety net in case a failed test run leaves one behind.
_test_scratch/

# Claude Code local machine settings (personal permission overrides)
.claude/settings.local.json

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
