<?xml version="1.0"?>
<!--
  Complexity: HIGH. Contains a ForEach Loop container, a Script Task
  with embedded C# (no static parser can extract its data lineage;
  this is the representative case for the LLM fallback / human-review
  flag), and an Execute SQL Task whose statement is dynamic SQL built
  via sp_executesql (also unresolved by sqlglot).
-->
<DTS:Executable
    xmlns:DTS="www.microsoft.com/SqlServer/Dts"
    xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask"
    xmlns:ScriptTask="www.microsoft.com/sqlserver/dts/tasks/scripttask"
    DTS:ExecutableType="Microsoft.Package">
  <DTS:Property DTS:Name="PackageFormatVersion">8</DTS:Property>
  <DTS:Property DTS:Name="ObjectName">Pkg_LoadOrderDetails</DTS:Property>
  <DTS:Property DTS:Name="VersionGUID">{11111111-0000-0000-0000-000000000003}</DTS:Property>

  <DTS:ConnectionManagers>
    <DTS:ConnectionManager DTS:refId="Package.ConnectionManagers[SalesDW]" DTS:CreationName="OLEDB" DTS:ObjectName="SalesDW">
      <DTS:ObjectData>
        <DTS:ConnectionManager ConnectionString="Data Source=SQLPRD01;Initial Catalog=SalesDW;Provider=SQLNCLI11.1;Integrated Security=SSPI;" />
      </DTS:ObjectData>
    </DTS:ConnectionManager>
  </DTS:ConnectionManagers>

  <DTS:Variables>
    <DTS:Variable DTS:ObjectName="RegionList" DTS:Namespace="User">
      <DTS:VariableValue DTS:DataType="8">EAST,WEST,CENTRAL</DTS:VariableValue>
    </DTS:Variable>
    <DTS:Variable DTS:ObjectName="CurrentRegion" DTS:Namespace="User">
      <DTS:VariableValue DTS:DataType="8"></DTS:VariableValue>
    </DTS:Variable>
  </DTS:Variables>

  <DTS:Executables>

    <DTS:Executable DTS:ExecutableType="STOCK:FOREACHLOOP" DTS:refId="Package\ForEach Region">
      <DTS:Property DTS:Name="ObjectName">ForEach Region</DTS:Property>
      <DTS:Executables>

        <DTS:Executable DTS:ExecutableType="STOCK:PipelineTask" DTS:refId="Package\ForEach Region\Load OrderDetails Flow">
          <DTS:Property DTS:Name="ObjectName">Load OrderDetails Flow</DTS:Property>
          <DTS:ObjectData>
            <pipeline version="1">
              <components>
                <component name="OLE DB Source - OrderDetails" componentClassID="Microsoft.OLEDBSource" connectionRef="SalesDW">
                  <properties>
                    <property name="AccessMode">2</property>
                    <property name="SqlCommand">SELECT od.OrderId, od.ProductId, od.Quantity, od.UnitPrice FROM dbo.OrderDetails od INNER JOIN dbo.Orders o ON o.OrderId = od.OrderId WHERE o.OrderDate &gt;= ?</property>
                  </properties>
                </component>
                <component name="OLE DB Destination - stg_OrderDetails" componentClassID="Microsoft.OLEDBDestination" connectionRef="SalesDW">
                  <properties>
                    <property name="AccessMode">3</property>
                    <property name="OpenRowset">[staging].[stg_OrderDetails]</property>
                  </properties>
                </component>
              </components>
              <paths>
                <path startId="OLE DB Source - OrderDetails" endId="OLE DB Destination - stg_OrderDetails" />
              </paths>
            </pipeline>
          </DTS:ObjectData>
        </DTS:Executable>

        <DTS:Executable DTS:ExecutableType="Microsoft.ScriptTask" DTS:refId="Package\ForEach Region\Apply Regional Discount Rules">
          <DTS:Property DTS:Name="ObjectName">Apply Regional Discount Rules</DTS:Property>
          <DTS:ObjectData>
            <ScriptTask:ScriptTaskData ScriptTask:Language="C#">
              <ScriptTask:ScriptCode><![CDATA[
public void Main()
{
    string region = (string)Dts.Variables["User::CurrentRegion"].Value;
    // Business rule embedded directly in script, not in any table/config:
    // regions "EAST"/"WEST" get a tiered discount applied to UnitPrice
    // before load; no equivalent SQL or declarative representation
    // exists elsewhere in this package. Flagged for LLM-assisted /
    // human-reviewed extraction -- this is exactly the construct no
    // static parser (sqlglot or XML) can resolve on its own.
    if (region == "EAST" || region == "WEST")
    {
        ApplyTieredDiscount(region);
    }
    Dts.TaskResult = (int)ScriptResults.Success;
}
]]></ScriptTask:ScriptCode>
            </ScriptTask:ScriptTaskData>
          </DTS:ObjectData>
        </DTS:Executable>

        <DTS:Executable DTS:ExecutableType="Microsoft.ExecuteSQLTask" DTS:refId="Package\ForEach Region\Dynamic Region Report">
          <DTS:Property DTS:Name="ObjectName">Dynamic Region Report</DTS:Property>
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
                SQLTask:Connection="SalesDW"
                SQLTask:SqlStatementSource="EXEC dbo.usp_DynamicReportBuilder @TableName = N'OrderDetails', @RegionFilter = ?;" />
          </DTS:ObjectData>
        </DTS:Executable>

      </DTS:Executables>
    </DTS:Executable>

  </DTS:Executables>

  <DTS:PrecedenceConstraints>
    <DTS:PrecedenceConstraint
        DTS:refId="Package\ForEach Region.PrecedenceConstraints[Flow To Script]"
        DTS:From="Package\ForEach Region\Load OrderDetails Flow"
        DTS:To="Package\ForEach Region\Apply Regional Discount Rules"
        DTS:Value="Success" />
    <DTS:PrecedenceConstraint
        DTS:refId="Package\ForEach Region.PrecedenceConstraints[Script To Report]"
        DTS:From="Package\ForEach Region\Apply Regional Discount Rules"
        DTS:To="Package\ForEach Region\Dynamic Region Report"
        DTS:Value="Success" />
  </DTS:PrecedenceConstraints>

</DTS:Executable>
