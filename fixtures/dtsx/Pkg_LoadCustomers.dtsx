<?xml version="1.0"?>
<!--
  Simplified representative .dtsx fixture for Autovista Discovery spike.
  Structure mirrors real SSIS 2012+ package XML (DTS:/SQLTask: namespaces
  and pipeline component shape) closely enough to exercise dtsx_xml_parser,
  but omits SSDT layout/ID boilerplate that carries no metadata value.
  Complexity: LOW (single data flow, one upstream Execute SQL Task).
-->
<DTS:Executable
    xmlns:DTS="www.microsoft.com/SqlServer/Dts"
    xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask"
    DTS:ExecutableType="Microsoft.Package">
  <DTS:Property DTS:Name="PackageFormatVersion">8</DTS:Property>
  <DTS:Property DTS:Name="ObjectName">Pkg_LoadCustomers</DTS:Property>
  <DTS:Property DTS:Name="VersionGUID">{11111111-0000-0000-0000-000000000001}</DTS:Property>

  <DTS:ConnectionManagers>
    <DTS:ConnectionManager DTS:refId="Package.ConnectionManagers[SalesDW]" DTS:CreationName="OLEDB" DTS:ObjectName="SalesDW">
      <DTS:ObjectData>
        <DTS:ConnectionManager ConnectionString="Data Source=SQLPRD01;Initial Catalog=SalesDW;Provider=SQLNCLI11.1;Integrated Security=SSPI;" />
      </DTS:ObjectData>
    </DTS:ConnectionManager>
  </DTS:ConnectionManagers>

  <DTS:Variables>
    <DTS:Variable DTS:ObjectName="BatchId" DTS:Namespace="User">
      <DTS:VariableValue DTS:DataType="3">0</DTS:VariableValue>
    </DTS:Variable>
  </DTS:Variables>

  <DTS:Executables>

    <DTS:Executable DTS:ExecutableType="Microsoft.ExecuteSQLTask" DTS:refId="Package\Truncate Staging Customers">
      <DTS:Property DTS:Name="ObjectName">Truncate Staging Customers</DTS:Property>
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
            SQLTask:Connection="SalesDW"
            SQLTask:SqlStatementSource="TRUNCATE TABLE staging.stg_Customers;" />
      </DTS:ObjectData>
    </DTS:Executable>

    <DTS:Executable DTS:ExecutableType="STOCK:PipelineTask" DTS:refId="Package\Load Customers Flow">
      <DTS:Property DTS:Name="ObjectName">Load Customers Flow</DTS:Property>
      <DTS:ObjectData>
        <pipeline version="1">
          <components>
            <component name="OLE DB Source - Customers" componentClassID="Microsoft.OLEDBSource" connectionRef="SalesDW">
              <properties>
                <property name="AccessMode">2</property>
                <property name="SqlCommand">SELECT CustomerId, CustomerName, Email, Region FROM dbo.Customers WHERE ModifiedDate &gt; ?</property>
              </properties>
            </component>
            <component name="Derived Column - Trim Email" componentClassID="Microsoft.DerivedColumn">
              <properties>
                <property name="Expression">TRIM(Email)</property>
              </properties>
            </component>
            <component name="OLE DB Destination - stg_Customers" componentClassID="Microsoft.OLEDBDestination" connectionRef="SalesDW">
              <properties>
                <property name="AccessMode">3</property>
                <property name="OpenRowset">[staging].[stg_Customers]</property>
              </properties>
            </component>
          </components>
          <paths>
            <path startId="OLE DB Source - Customers" endId="Derived Column - Trim Email" />
            <path startId="Derived Column - Trim Email" endId="OLE DB Destination - stg_Customers" />
          </paths>
        </pipeline>
      </DTS:ObjectData>
    </DTS:Executable>

  </DTS:Executables>

  <DTS:PrecedenceConstraints>
    <DTS:PrecedenceConstraint
        DTS:refId="Package.PrecedenceConstraints[Truncate To Load]"
        DTS:From="Package\Truncate Staging Customers"
        DTS:To="Package\Load Customers Flow"
        DTS:Value="Success" />
  </DTS:PrecedenceConstraints>

</DTS:Executable>
