<?xml version="1.0"?>
<!--
  Complexity: MEDIUM. Execute SQL Task calling a parameterized stored
  procedure (package -> proc dependency, resolved via sql_lineage_parser
  on the proc body) plus a File System Task (no SQL/table lineage, but
  a real control-flow node that must still be inventoried).
-->
<DTS:Executable
    xmlns:DTS="www.microsoft.com/SqlServer/Dts"
    xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask"
    DTS:ExecutableType="Microsoft.Package">
  <DTS:Property DTS:Name="PackageFormatVersion">8</DTS:Property>
  <DTS:Property DTS:Name="ObjectName">Pkg_ArchiveOldData</DTS:Property>
  <DTS:Property DTS:Name="VersionGUID">{11111111-0000-0000-0000-000000000004}</DTS:Property>

  <DTS:ConnectionManagers>
    <DTS:ConnectionManager DTS:refId="Package.ConnectionManagers[SalesDW]" DTS:CreationName="OLEDB" DTS:ObjectName="SalesDW">
      <DTS:ObjectData>
        <DTS:ConnectionManager ConnectionString="Data Source=SQLPRD01;Initial Catalog=SalesDW;Provider=SQLNCLI11.1;Integrated Security=SSPI;" />
      </DTS:ObjectData>
    </DTS:ConnectionManager>
    <DTS:ConnectionManager DTS:refId="Package.ConnectionManagers[ArchiveShare]" DTS:CreationName="FILE" DTS:ObjectName="ArchiveShare">
      <DTS:ObjectData>
        <DTS:ConnectionManager ConnectionString="\\fileserver01\archive\salesdw" />
      </DTS:ObjectData>
    </DTS:ConnectionManager>
  </DTS:ConnectionManagers>

  <DTS:Variables>
    <DTS:Variable DTS:ObjectName="CutoffDate" DTS:Namespace="User">
      <DTS:VariableValue DTS:DataType="7">2023-01-01T00:00:00</DTS:VariableValue>
    </DTS:Variable>
  </DTS:Variables>

  <DTS:Executables>

    <DTS:Executable DTS:ExecutableType="Microsoft.ExecuteSQLTask" DTS:refId="Package\Exec usp_ArchiveOldOrders">
      <DTS:Property DTS:Name="ObjectName">Exec usp_ArchiveOldOrders</DTS:Property>
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
            SQLTask:Connection="SalesDW"
            SQLTask:SqlStatementSource="EXEC dbo.usp_ArchiveOldOrders @CutoffDate = ?;" />
      </DTS:ObjectData>
    </DTS:Executable>

    <DTS:Executable DTS:ExecutableType="Microsoft.FileSystemTask" DTS:refId="Package\Move Archive Extract">
      <DTS:Property DTS:Name="ObjectName">Move Archive Extract</DTS:Property>
      <DTS:Property DTS:Name="Operation">MoveFile</DTS:Property>
      <DTS:Property DTS:Name="Source">ArchiveShare</DTS:Property>
      <DTS:Property DTS:Name="Destination">ArchiveShare\processed</DTS:Property>
    </DTS:Executable>

  </DTS:Executables>

  <DTS:PrecedenceConstraints>
    <DTS:PrecedenceConstraint
        DTS:refId="Package.PrecedenceConstraints[Archive To Move]"
        DTS:From="Package\Exec usp_ArchiveOldOrders"
        DTS:To="Package\Move Archive Extract"
        DTS:Value="Success" />
  </DTS:PrecedenceConstraints>

</DTS:Executable>
